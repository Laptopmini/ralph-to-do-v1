{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(rm src/*)",
      "Bash(rm tests/*)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.cert)",
      "Bash(rm -rf *)",
      "Read(docs/*)",
      "Glob(docs/*)",
      "Grep(docs/*)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git stash *)",
      "Bash(rm src/*)",
      "Bash(rm tests/*)",
      "Write(.github/scripts/ralph.sh)",
      "Edit(.github/scripts/ralph.sh)",
      "Bash(*.github/scripts/ralph.sh*)",
      "Write(.github/scripts/backpressure.sh)",
      "Edit(.github/scripts/backpressure.sh)",
      "Bash(*.github/scripts/backpressure.sh*)",
      "Write(.github/scripts/fork.sh)",
      "Edit(.github/scripts/fork.sh)",
      "Bash(*.github/scripts/fork.sh*)",
      "Write(.github/scripts/maestro.sh)",
      "Edit(.github/scripts/maestro.sh)",
      "Bash(*.github/scripts/maestro.sh*)",
      "Write(.github/scripts/prompt.sh)",
      "Edit(.github/scripts/prompt.sh)",
      "Bash(*.github/scripts/prompt.sh*)",
      "Bash(npm run ralph*)",
      "Bash(npm run backpressure*)",
      "Bash(npm run maestro*)",
      "Write(.github/prompts/ralph.md)",
      "Edit(.github/prompts/ralph.md)",
      "Bash(*.github/prompts/ralph.md*)"
    ]
  }
}
