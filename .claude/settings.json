      "Bash(* .github/scripts/**)",
      "Write(.github/prompts**)",
      "Edit(.github/prompts**)",
      "Bash(* .github/prompts**)",
      "Bash(npm run ralph*)",
      "Bash(npm run backpressure*)",
      "Bash(npm run maestro*)",
      "Read(.maestro.claude.tmp)",
